{
  "name": "@divyangbissadev/agent-army",
  "version": "3.6.0",
  "description": "Elite pluggable team of software engineering agents, skills, and commands for Claude Code. TDD, DDD, spec-driven changes, compounding learnings, token-frugal. Installs via npx or as a Claude Code plugin.",
  "bin": {
    "agent-army": "bin/cli.js"
  },
  "files": [
    "bin",
    "agents",
    "skills",
    "commands",
    "hooks",
    "scripts",
    "army",
    ".claude-plugin",
    "README.md",
    "THIRD-PARTY-NOTICES.md",
    "eval",
    "GUIDE.md"
  ],
  "scripts": {
    "test": "node --test test/*.test.js",
    "eval:list": "node scripts/score-intake.mjs list",
    "eval:score": "node scripts/score-intake.mjs score",
    "e2e": "node scripts/run-e2e.mjs list"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "claude-code",
    "agents",
    "subagents",
    "skills",
    "plugin",
    "tdd",
    "ddd",
    "spec-driven",
    "agentic-workflow",
    "code-review",
    "orchestration"
  ],
  "author": "Divyang Bissa <dbissa94@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/divyangbissadev/agent-army.git"
  },
  "bugs": {
    "url": "https://github.com/divyangbissadev/agent-army/issues"
  },
  "homepage": "https://github.com/divyangbissadev/agent-army#readme"
}
